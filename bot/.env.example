# Discord bot token — Discord Developer Portal → your app → Bot → Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Your Discord server ID — right-click server name → Copy Server ID
DISCORD_GUILD_ID=your_guild_id_here

# A secret string you make up — must match what you set in the Supabase webhook header
WEBHOOK_SECRET=make_up_a_secret_string_here

# Port — Railway sets this automatically, leave as 3000 for local testing
PORT=3000
